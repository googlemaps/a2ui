{
  "name": "@googlemaps/a2ui",
  "version": "0.1.7",
  "description": "Maps Agentic UI Toolkit Library",
  "main": "./dist/src/lit/index.js",
  "types": "./dist/src/lit/index.d.ts",
  "exports": {
    "./lit": {
      "types": "./dist/src/lit/index.d.ts",
      "default": "./dist/src/lit/index.js"
    },
    "./lit/custom-components": {
      "types": "./dist/src/lit/custom-components/index.d.ts",
      "default": "./dist/src/lit/custom-components/index.js"
    }
  },
  "type": "module",
  "scripts": {
    "prepack": "npm run build",
    "build": "wireit",
    "build:tsc": "wireit",
    "dev": "npm run serve --watch",
    "serve": "wireit",
    "build-and-link": "npm install && npm run build && npm link"
  },
  "wireit": {
    "serve": {
      "command": "vite dev",
      "dependencies": [
        "build"
      ],
      "service": true
    },
    "build": {
      "dependencies": [
        "build:tsc"
      ]
    },
    "build:tsc": {
      "command": "tsc -b --pretty",
      "env": {
        "FORCE_COLOR": "1"
      },
      "files": [
        "src/**/*.ts",
        "src/**/*.json",
        "tsconfig.json"
      ],
      "output": [
        "dist/",
        "!dist/**/*.min.js{,.map}"
      ],
      "clean": "if-file-deleted"
    }
  },
  "files": [
    "dist/src"
  ],
  "keywords": [
    "google",
    "maps",
    "agentic",
    "ui",
    "a2ui",
    "visualization",
    "grounding"
  ],
  "author": "Google",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/googlemaps/a2ui.git"
  },
  "devDependencies": {
    "@types/google.maps": "^3.64.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "google-artifactregistry-auth": "^3.5.0",
    "typescript": "^5.8.3",
    "wireit": "^0.15.0-pre.2"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.8",
    "@a2ui/lit": "^0.9.3",
    "@a2ui/markdown-it": "^0.0.3",
    "@lit-labs/signals": "^0.1.3",
    "@lit/context": "^1.1.4",
    "lit": "^3.3.1",
    "markdown-it": "^14.1.0",
    "signal-utils": "^0.21.1"
  }
}
